# Generate a unique 32-byte secret; never commit the real value.
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Create a GitHub OAuth App whose callback is:
# http://localhost:3000/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Positive decimal GitHub account ID, not a username or Better Auth user ID.
GITHUB_OWNER_ID=

# Leave blank locally. Production requires exactly one supported provider header;
# see docs/operations.md.
AUTH_CLIENT_IP_HEADER=

# Generate a second independent 32-byte secret.
PUBLIC_TIMELINE_CURSOR_SECRET=

# Local development uses the ignored apps/shika/.data directory.
# Remote Turso uses a libsql:// URL and requires TURSO_AUTH_TOKEN.
TURSO_DATABASE_URL=file:.data/shika.db
TURSO_AUTH_TOKEN=
