{
  "name": "@cedarflake/youtube-auto-resume",
  "version": "0.2.1",
  "private": true,
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=22 <25"
  },
  "scripts": {
    "build": "node --experimental-strip-types scripts/build.ts",
    "build:check": "node --experimental-strip-types scripts/build.ts --check",
    "check": "tsc --noEmit && node --experimental-strip-types --test tests/settings.test.ts tests/panelMount.test.ts && node --experimental-strip-types scripts/build.ts --check && node --check dist/youtube-auto-resume.user.js && node --experimental-strip-types --test tests/panel.e2e.ts",
    "test": "node --experimental-strip-types --test tests/settings.test.ts tests/panelMount.test.ts",
    "test:e2e": "node --experimental-strip-types --test tests/panel.e2e.ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "22.10.5",
    "esbuild": "0.25.0",
    "playwright": "1.61.1",
    "typescript": "5.7.3"
  }
}
