{
  "name": "@igcrystal/focus-orb",
  "version": "0.1.0",
  "description": "Reusable React WebGL focus orb component.",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./style.css": "./dist/style.css",
    "./noise-watercolor-m3j88gni.webp": "./dist/assets/noise-watercolor-m3j88gni.webp"
  },
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json --emitDeclarationOnly",
    "check": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "react": ">=18.2.0 || >=19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.2",
    "react": "^19.0.0"
  }
}
