{
  "name": "@cedarflake/focus-orb",
  "version": "0.1.0",
  "description": "Reusable React WebGL focus orb component.",
  "license": "BSD-3-Clause",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Cedarflake/Cedarflake-Lab.git",
    "directory": "packages/focus-orb"
  },
  "homepage": "https://github.com/Cedarflake/Cedarflake-Lab/tree/main/packages/focus-orb#readme",
  "bugs": {
    "url": "https://github.com/Cedarflake/Cedarflake-Lab/issues"
  },
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./style.css": "./dist/style.css",
    "./noise-watercolor-m3j88gni.webp": {
      "types": "./dist/assets/noise-watercolor-m3j88gni.webp.d.ts",
      "default": "./dist/assets/noise-watercolor-m3j88gni.webp"
    }
  },
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json --emitDeclarationOnly && node scripts/copyAssets.mjs",
    "check": "tsc -p tsconfig.json --noEmit",
    "pack:check": "pnpm run build && pnpm run test:package-contract && node scripts/checkPackage.mjs",
    "test:package-contract": "node --test scripts/packageContract.test.mjs",
    "prepack": "pnpm run build"
  },
  "peerDependencies": {
    "react": "^18.2.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.2",
    "react": "^19.0.0",
    "typescript": "^5.7.3",
    "vite": "^6.4.3"
  }
}
