{
  "name": "cedarflake-lab",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@11.7.0",
  "type": "module",
  "engines": {
    "node": ">=22 <25"
  },
  "scripts": {
    "build": "pnpm -r --filter \"./apps/**\" --filter \"./packages/**\" --if-present build",
    "check": "pnpm -r --filter \"./apps/**\" --filter \"./packages/**\" --if-present check",
    "lint": "pnpm -r --filter \"./apps/**\" --filter \"./packages/**\" --if-present lint",
    "typecheck": "pnpm -r --filter \"./apps/**\" --filter \"./packages/**\" --if-present typecheck",
    "format": "pnpm -r --filter \"./apps/**\" --filter \"./packages/**\" --if-present format",
    "format:check": "pnpm -r --filter \"./apps/**\" --filter \"./packages/**\" --if-present format:check",
    "dev:copilot-task": "pnpm --filter tasks-waitlist-preview dev",
    "dev:focus-orb": "pnpm --filter @cedarflake/focus-orb-demo dev",
    "dev:liminal-drift": "pnpm --filter liminal-drift dev",
    "dev:maimai-transition": "pnpm --filter maimai-transition dev",
    "dev:shika": "pnpm --filter shika dev",
    "email": "pnpm --filter personal_email email",
    "render:email": "pnpm --filter personal_email render:email",
    "check:focus-orb-package": "pnpm --filter @cedarflake/focus-orb build && pnpm --filter @cedarflake/focus-orb-demo exec tsc -p package-consumer/tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "22.10.5",
    "@vitejs/plugin-react": "4.3.4",
    "typescript": "5.7.3",
    "vite": "6.0.7"
  }
}
